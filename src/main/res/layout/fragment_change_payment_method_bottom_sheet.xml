<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    tools:context=".ui.general.ChangePaymentMethodBottomSheet">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_alert"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Change Payment Method"
            android:fontFamily="@font/din_next_lt_pro"
            android:layout_marginTop="20dp"
            android:textStyle="bold"
            android:textSize="20sp"
            android:textColor="#2C333C"
            />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Changing the payment method will make the payment code unusable. Are you sure want to change payment ?"
            android:layout_marginTop="8dp"
            android:textSize="16sp"
            android:fontFamily="@font/din_next_lt_pro"
            android:textFontWeight="400"
            android:textColor="#545B65"
            />

        <com.google.android.material.card.MaterialCardView
            android:layout_marginTop="16dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:backgroundTint="#E1251B"
            app:cardCornerRadius="4dp"
            app:cardElevation="0dp"
            android:id="@+id/positiveBtn">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:padding="14dp"
                android:fontFamily="@font/din_next_lt_pro"
                android:text="Change"
                android:textColor="#FFFFFF"
                android:gravity="center"/>

        </com.google.android.material.card.MaterialCardView>


        <com.google.android.material.card.MaterialCardView
            android:layout_marginTop="16dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#FFFFFF"
            app:cardCornerRadius="4dp"
            app:cardElevation="0dp"
            app:strokeColor="#E1251B"
            app:strokeWidth="1dp"
            android:id="@+id/negativeBtn">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:padding="14dp"
                android:fontFamily="@font/din_next_lt_pro"
                android:text="No"
                android:textColor="#E1251B"
                android:gravity="center"/>

        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>

</FrameLayout>