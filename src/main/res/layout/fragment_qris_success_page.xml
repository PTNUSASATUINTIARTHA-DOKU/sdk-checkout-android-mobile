<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:paddingTop="4dp"
    android:paddingHorizontal="16dp"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal">

        <!-- Card Background -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_with_stroke"
            android:padding="16dp">

            <!-- Title -->
            <TextView
                android:id="@+id/tvTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginBottom="4dp"
                android:gravity="center"
                android:text="Scan QR Code to Pay"
                android:fontFamily="@font/din_next_lt_pro"
                android:textColor="#2C333C"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textFontWeight="500"/>

            <!-- NMID -->
            <TextView
                android:id="@+id/tvNmid"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:gravity="center"
                android:layout_gravity="center_horizontal"
                android:fontFamily="@font/din_next_lt_pro"
                android:text="NMID: -"
                android:textColor="#2C333C"
                android:textSize="16sp" />

            <!-- QR Image -->
            <ImageView
                android:id="@+id/ivQrCode"
                android:layout_width="200dp"
                android:layout_height="200dp"
                android:layout_gravity="center"
                android:fontFamily="@font/din_next_lt_pro"
                android:contentDescription="generatedQris"
                android:layout_marginBottom="12dp" />

            <com.google.android.material.card.MaterialCardView
                android:layout_height="48dp"
                android:layout_width="match_parent"
                android:background="#FFFFFF"
                app:cardCornerRadius="4dp"
                app:cardElevation="0dp"
                app:strokeColor="#ABB4C0"
                android:id="@+id/btnDownloadQr"
                app:strokeWidth="1dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:padding="14dp"
                    android:fontFamily="@font/din_next_lt_pro"
                    android:text="Download QR"
                    android:textSize="14sp"
                    android:textColor="#2C333C"
                    android:textFontWeight="500"
                    android:gravity="center"/>

            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>


        <!-- HOW TO PAY DROPDOWN -->
        <LinearLayout
            android:id="@+id/layoutHowToPay"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="16dp">

            <LinearLayout
                android:id="@+id/btnToggleHowTo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_how_to_pay"
                android:padding="12dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="How To Pay"
                    android:fontFamily="@font/din_next_lt_pro"
                    android:textColor="#2C333C"
                    android:textFontWeight="500"
                    android:textSize="14sp" />

                <ImageView
                    android:id="@+id/icChevron"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_chevron_down" />
            </LinearLayout>

        </LinearLayout>

        <!-- Change Payment Method -->
        <TextView
            android:id="@+id/btnChangePaymentMethod"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Change Payment Method"
            android:fontFamily="@font/din_next_lt_pro"
            android:textColor="#E1251B"
            android:textStyle="bold"
            android:textFontWeight="500"
            android:textSize="14sp"
            android:layout_marginVertical="16dp" />
    </LinearLayout>

</ScrollView>
